# RPG-MCP environment configuration
# Copy this file to .env and fill in the values you need.
# .env is gitignored — never commit credentials.

# ─── LLM provider keys for agent_manage (optional) ────────────────────────────
# Set one or both. Agents can be configured per-character to use either provider.
# When invoked without a configured key, agent_manage returns status='error' with
# a clear "set OPENAI_API_KEY"/"set OPENROUTER_API_KEY" message — never crashes.

# OPENAI_API_KEY=sk-...
# OPENAI_ORGANIZATION=org-...                  # optional, only if you use orgs

# OPENROUTER_API_KEY=or-...
# OPENROUTER_REFERER=https://questkeeper.local # OpenRouter attribution header
# OPENROUTER_TITLE=Quest Keeper AI             # OpenRouter attribution header

# ─── Storage ─────────────────────────────────────────────────────────────────
# Override the working directory for rpg.db (defaults to CWD).
# RPG_DATA_DIR=/path/to/state

# ─── Transport security (optional, only relevant for TCP/WS transports) ──────
# Token clients must present in the Authorization header on non-loopback hosts.
# RPG_MCP_TRANSPORT_TOKEN=your-shared-secret
